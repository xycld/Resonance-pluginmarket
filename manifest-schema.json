{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["manifest_version", "name", "version", "description", "author", "permissions", "hooks", "providers", "entry", "api_version"],
  "properties": {
    "manifest_version": { "const": 3, "description": "Fixed to 3" },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "Plugin unique identifier, kebab-case" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+", "description": "Semantic version" },
    "description": { "type": "string", "maxLength": 200 },
    "author": { "type": "string" },
    "permissions": {
      "type": "array",
      "items": { "enum": ["storage", "network", "content:read", "content:write", "audio:read", "audio:write", "fs"] }
    },
    "hooks": { "type": "array", "items": { "type": "string" } },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "capabilities"],
        "properties": {
          "type": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "entry": { "type": "string", "description": "Main process entry filename (e.g. index.js)" },
    "ui_entry": { "type": "string", "description": "Renderer entry filename (e.g. ui.js)" },
    "cover": { "type": "string", "description": "Cover image path relative to plugin root" },
    "api_version": { "type": "string", "pattern": "^3\\.", "description": "API version, must be 3.x" }
  }
}
